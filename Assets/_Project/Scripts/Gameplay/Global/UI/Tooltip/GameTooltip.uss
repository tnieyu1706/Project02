.tooltip-container {
    background-color: antiquewhite;
    padding: 8px;
    
    border-radius: 6px;
    border-color: black;
    border-width: 2px;
    
    min-width: 60px;
    max-width: 300px;
    
    min-height: 20px;
    max-height: 600px;
    
    white-space: normal;
}

.text-tooltip {
    width: 100%;
    height: 100%;
    -unity-text-align: middle-center;
    font-size: 12px;
    -unity-font-style: bold;
    
    white-space: normal;
}